# Memora — environment variables
# Copy this file to .env and fill with values from your Supabase project (Settings → API).

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: force offline demo mode even when Supabase creds are present.
# Useful during early development before real users are provisioned.
# Set to "true" to bypass Supabase auth and accept the two seed demo accounts
# (angelo.casula@gmail.com / maurizio.cocco@memora.app) with any password.
EXPO_PUBLIC_DEMO_MODE=false
